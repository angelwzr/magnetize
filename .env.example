PORT=3000
NODE_ENV=production

# Feature Flags
# Enable/disable API endpoint (default: true)
ENABLE_API=true

# API Security (optional - auto-generated if not set)
# API_KEY=your_api_key_here

# Proxy Configuration (optional)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1
# PROXY_USERNAME=user
# PROXY_PASSWORD=pass
